{
  "name": "spark-template",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:frontend": "vite --host 0.0.0.0 --port 5000",
    "backend": "python -m uvicorn backend.api_server:app --host 0.0.0.0 --port 8001 --reload",
    "dev:all": "concurrently \"npm run backend\" \"npm run dev:frontend\"",
    "sync": "bash scripts/auto_sync.sh",
    "sync:safe": "bash scripts/safe_sync.sh",
    "kill": "npx --yes kill-port 5000 8001",
    "dev:nohup": "bash scripts/start_dev.sh",
    "build:frontend": "vite build",
    "build:backend": "echo 'Backend build step placeholder'",
    "build": "tsc -b --noCheck && vite build",
    "lint": "eslint .",
    "optimize": "vite optimize",
    "preview": "vite preview",
    "test": "vitest run",
    "test:smoke": "pytest -k smoke -q",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "snapshots:capture": "playwright test --config=playwright.config.ts && tsx tests/visual/report.ts",
    "snapshots:approve": "tsx tests/visual/approve.ts",
    "snapshots:approve-all": "tsx tests/visual/approve.ts --all",
    "snapshots:show": "cross-env MSYS_NO_PATHCONV=1 tsx tests/visual/show.ts",
    "snapshots:audit": "tsx tests/visual/audit.ts",
    "snapshots:report": "tsx tests/visual/report.ts",
    "gen:openapi": "python scripts/dump_openapi.py",
    "gen:types": "npm run gen:openapi && openapi-typescript build/openapi.json --output src/types/api.ts"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.7",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.4.2",
    "@react-three/postprocessing": "^3.0.4",
    "@tanstack/react-query": "^5.83.1",
    "@types/three": "^0.182.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "date-fns": "^3.6.0",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.5",
    "framer-motion": "^12.6.2",
    "lightweight-charts": "^5.1.0",
    "lucide-react": "^0.484.0",
    "numeral": "^2.0.6",
    "postprocessing": "^6.38.1",
    "react": "^19.0.0",
    "react-day-picker": "^9.6.7",
    "react-dom": "^19.0.0",
    "react-error-boundary": "^6.0.0",
    "react-router-dom": "^7.9.6",
    "three": "^0.175.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.1.3",
    "@eslint/js": "^9.21.0",
    "@playwright/test": "^1.59.1",
    "@storybook/addon-a11y": "^10.1.10",
    "@storybook/addon-docs": "^10.1.10",
    "@storybook/addon-onboarding": "^10.1.10",
    "@storybook/react-vite": "^10.1.10",
    "@types/pixelmatch": "^5.2.6",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitejs/plugin-react-swc": "^3.10.1",
    "@vitest/browser": "^2.1.0",
    "@vitest/coverage-v8": "^2.1.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.28.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "eslint-plugin-storybook": "^10.1.10",
    "globals": "^16.0.0",
    "openapi-typescript": "^7.13.0",
    "pixelmatch": "^7.2.0",
    "playwright": "^1.57.0",
    "pngjs": "^7.0.0",
    "storybook": "^10.1.10",
    "tsx": "^4.21.0",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.48.0",
    "vite": "^6.4.1",
    "vitest": "^2.1.0"
  },
  "workspaces": {
    "packages": [
      "packages/*"
    ]
  },
  "eslintConfig": {
    "extends": [
      "plugin:storybook/recommended"
    ]
  }
}
